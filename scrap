local function ToggleESP()
    ESPEnabled = not ESPEnabled
    if ESPEnabled then
        ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        ToggleButton.Text = "Scrap ESP: ON"
        ScanForScrap()
        MonitorScrap()
    else
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        ToggleButton.Text = "Scrap ESP: OFF"
        ClearESPByType("Scrap")
    end
end

local function ToggleTrapESP()
    BearTrapESPEnabled = not BearTrapESPEnabled
    if BearTrapESPEnabled then
        TrapToggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        TrapToggleButton.Text = "Trap ESP: ON"
        ScanForBearTraps()
        MonitorBearTraps()
    else
        TrapToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        TrapToggleButton.Text = "Trap ESP: OFF"
        ClearESPByType("BearTrap")
    end
end

local function ToggleLootESP()
    LootESPEnabled = not LootESPEnabled
    if LootESPEnabled then
        LootToggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        LootToggleButton.Text = "Loot ESP: ON"
        ScanForLoot()
        MonitorLoot()
    else
        LootToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        LootToggleButton.Text = "Loot ESP: OFF"
        ClearESPByType("Loot")
    end
end

local function ToggleAutoCollect()
    AutoCollectEnabled = not AutoCollectEnabled
    if AutoCollectEnabled then
        AutoButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        AutoButton.Text = "Auto-Collect: ON"
        
        if not ESPEnabled then ScanForScrap() MonitorScrap() end
        if not LootESPEnabled then ScanForLoot() MonitorLoot() end
    else
        AutoButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        AutoButton.Text = "Auto-Collect: OFF"
    end
end

ToggleButton.MouseButton1Click:Connect(ToggleESP)
TrapToggleButton.MouseButton1Click:Connect(ToggleTrapESP)
LootToggleButton.MouseButton1Click:Connect(ToggleLootESP)
AutoButton.MouseButton1Click:Connect(ToggleAutoCollect)

