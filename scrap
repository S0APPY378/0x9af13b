-- ─────────────────────────────────────────────
-- ESP object helpers
-- ─────────────────────────────────────────────

local function CreateESP(targetObject, objType)
    if ESPObjects[targetObject] then return end

    local Billboard = Instance.new("BillboardGui")
    Billboard.Name = objType .. "ESP"
    Billboard.AlwaysOnTop = true
    Billboard.Size = UDim2.new(0, 200, 0, 50)
    Billboard.StudsOffset = Vector3.new(0, 2, 0)
    Billboard.Adornee = targetObject
    Billboard.Parent = targetObject

    local TextLabel = Instance.new("TextLabel")
    TextLabel.Size = UDim2.new(1, 0, 1, 0)
    TextLabel.BackgroundTransparency = 1
    TextLabel.TextSize = TextSize
    TextLabel.Font = Enum.Font.GothamBold
    TextLabel.TextStrokeTransparency = 0.5
    TextLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    
    if objType == "BearTrap" then
        TextLabel.TextColor3 = BearTrapColor
        TextLabel.Text = "BEAR TRAP"
    elseif objType == "Loot" then
        TextLabel.TextColor3 = LootColor
        TextLabel.Text = string.upper(targetObject.Name)
    else
        TextLabel.TextColor3 = ESPColor
        TextLabel.Text = "SCRAP"
    end
    
    TextLabel.Parent = Billboard

    ESPObjects[targetObject] = {
        Billboard = Billboard,
        TextLabel = TextLabel,
        Type = objType
    }
end

local function RemoveESP(targetObject)
    local esp = ESPObjects[targetObject]
    if esp then
        esp.Billboard:Destroy()
        ESPObjects[targetObject] = nil
    end
end

local function ClearESPByType(objType)
    for obj, esp in pairs(ESPObjects) do
        if esp.Type == objType then
            esp.Billboard:Destroy()
            ESPObjects[obj] = nil
        end
    end
end

-- ─────────────────────────────────────────────
-- Folder caching & scanning
-- ─────────────────────────────────────────────

local ScrapFolder = nil
local BearTrapFolder = nil
local LootablesFolder = nil

local function GetScrapFolder()
    if ScrapFolder and ScrapFolder.Parent then return ScrapFolder end
    local ok, result = pcall(function()
        local Misc = Workspace:FindFirstChild("Misc")
        if not Misc then return nil end
        local Zones = Misc:FindFirstChild("Zones")
        if not Zones then return nil end
        local LootingItems = Zones:FindFirstChild("LootingItems")
        if not LootingItems then return nil end
        return LootingItems:FindFirstChild("Scrap")
    end)
    ScrapFolder = ok and result or nil
    return ScrapFolder
end

local function GetBearTrapFolder()
    if BearTrapFolder and BearTrapFolder.Parent then return BearTrapFolder end
    local ok, result = pcall(function()
        local GameStuff = Workspace:FindFirstChild("GameStuff")
        if not GameStuff then return nil end
        local PlayerStuff = GameStuff:FindFirstChild("PlayerStuff")
        if not PlayerStuff then return nil end
        return PlayerStuff:FindFirstChild("BearTraps")
    end)
    BearTrapFolder = ok and result or nil
    return BearTrapFolder
end

local function GetLootablesFolder()
    if LootablesFolder and LootablesFolder.Parent then return LootablesFolder end
    local ok, result = pcall(function()
        local Misc = Workspace:FindFirstChild("Misc")
        if not Misc then return nil end
        return Misc:FindFirstChild("Lootables")
    end)
    LootablesFolder = ok and result or nil
    return LootablesFolder
end

local function ScanForScrap()
    local folder = GetScrapFolder()
    if not folder then return end
    for _, v in ipairs(folder:GetChildren()) do
        if v:GetAttribute("Scrap") or v:IsA("Model") or v:IsA("Part") then
            CreateESP(v, "Scrap")
        end
    end
end

local function ScanForBearTraps()
    local folder = GetBearTrapFolder()
    if not folder then return end
    for _, v in ipairs(folder:GetChildren()) do
        if v:IsA("Model") and v.Name == "BearTrap" then
            CreateESP(v, "BearTrap")
        end
    end
end

local function ScanForLoot()
    local folder = GetLootablesFolder()
    if not folder then return end
    
    for _, container in ipairs(folder:GetChildren()) do
        local itemsFolder = container:FindFirstChild("Items")
        if itemsFolder then
            for _, item in ipairs(itemsFolder:GetChildren()) do
                CreateESP(item, "Loot")
            end
        end
    end
end

-- ─────────────────────────────────────────────
-- Combined RenderStepped tick
-- ─────────────────────────────────────────────

local lastESPUpdate = 0
local UPDATE_INTERVAL = 0.2
local lastAutoCollect = 0
local AUTO_COLLECT_INTERVAL = 0.15

RunService.Heartbeat:Connect(function()
    local character = Player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local hrpPos = hrp.Position

    local now = tick()
    local doFullUpdate = (now - lastESPUpdate) >= UPDATE_INTERVAL
    local doAutoCollect = AutoCollectEnabled and (now - lastAutoCollect) >= AUTO_COLLECT_INTERVAL

    local distSqLimit = AutoCollectDistance * AutoCollectDistance
    local bestObj, bestDistSq = nil, distSqLimit

    for targetObject, espData in pairs(ESPObjects) do
        -- Clear ESP if object is destroyed or moved out of workspace
        if not (targetObject and targetObject.Parent) then
            RemoveESP(targetObject)
            continue
        end

        local position = targetObject:IsA("Model")
            and targetObject:GetPivot().Position
            or targetObject.Position

        local dx = hrpPos.X - position.X
        local dy = hrpPos.Y - position.Y
        local dz = hrpPos.Z - position.Z
        local distSq = dx*dx + dy*dy + dz*dz

        -- ESP Logic
        local isTargetESPEnabled = 
            (espData.Type == "Scrap" and ESPEnabled) or 
            (espData.Type == "BearTrap" and BearTrapESPEnabled) or
            (espData.Type == "Loot" and LootESPEnabled)
        
        if isTargetESPEnabled then
            if distSq <= MaxDistanceSq then
                espData.Billboard.Enabled = true
                if doFullUpdate then
                    local dist = math.sqrt(distSq)

                    if espData.Type == "Scrap" then
                        local isAvailable = false
                        if targetObject:IsA("Model") then
                            local valuesFolder = targetObject:FindFirstChild("Values")
                            if valuesFolder then
                                isAvailable = valuesFolder:GetAttribute("Available") == true
                            end
                        end

                        espData.TextLabel.TextColor3 = isAvailable
                            and Color3.fromRGB(0, 255, 0)
                            or ESPColor

                        espData.TextLabel.Text = "SCRAP\n"
                            .. math.round(position.X) .. ", "
                            .. math.round(position.Y) .. ", "
                            .. math.round(position.Z)
                            .. "\n" .. math.round(dist) .. " studs"
                            
                    elseif espData.Type == "BearTrap" then
                        espData.TextLabel.TextColor3 = BearTrapColor
                        espData.TextLabel.Text = "BEAR TRAP\n" .. math.round(dist) .. " studs"
                        
                    elseif espData.Type == "Loot" then
                        espData.TextLabel.TextColor3 = LootColor
                        espData.TextLabel.Text = string.upper(targetObject.Name) .. "\n" .. math.round(dist) .. " studs"
                    end
                end
            else
                espData.Billboard.Enabled = false
            end
        else
            espData.Billboard.Enabled = false
        end

        -- Auto-collect (Target Scrap and Loot, NEVER BearTraps)
        if doAutoCollect and (espData.Type == "Scrap" or espData.Type == "Loot") then
            local available = true
            
            -- Only check Available attributes for scrap
            if espData.Type == "Scrap" then
                if targetObject:IsA("Model") then
                    local vals = targetObject:FindFirstChild("Values")
                    available = vals and vals:GetAttribute("Available") == true
                else
                    available = targetObject:GetAttribute("Available") == true
                end
            end

            if available and distSq < bestDistSq then
                bestDistSq = distSq
                bestObj = targetObject
            end
        end
    end

    if doFullUpdate then lastESPUpdate = now end

    if doAutoCollect then
        lastAutoCollect = now
        if bestObj then
            local prompt = bestObj:IsA("Model")
                and bestObj:FindFirstChildWhichIsA("ProximityPrompt", true)
                or bestObj:FindFirstChildWhichIsA("ProximityPrompt")
            if prompt then
                fireproximityprompt(prompt)
            end
        end
    end
end)

-- ─────────────────────────────────────────────
-- Scrap inventory tracking
-- ─────────────────────────────────────────────

local function SetupScrapTracking()
    local function refreshLabel()
        local character = Player.Character
        if not character then ScrapAmountLabel.Text = "Scrap: N/A" return end
        local items = character:FindFirstChild("Items")
        local amount = items and items:GetAttribute("Scrap") or 0
        ScrapAmountLabel.Text = "Scrap: " .. tostring(amount)
    end

    local function hookCharacter(character)
        refreshLabel()
        local items = character:WaitForChild("Items", 5)
        if items then
            items:GetAttributeChangedSignal("Scrap"):Connect(refreshLabel)
        end
    end

    if Player.Character then hookCharacter(Player.Character) end
    Player.CharacterAdded:Connect(hookCharacter)
end

SetupScrapTracking()

-- ─────────────────────────────────────────────
-- Folder monitoring (ChildAdded / DescendantAdded)
-- ─────────────────────────────────────────────

local scrapMonitorStarted = false
local trapMonitorStarted = false
local lootMonitorStarted = false

local function MonitorScrap()
    if scrapMonitorStarted then return end
    local folder = GetScrapFolder()
    if not folder then
        task.delay(1, MonitorScrap)
        return
    end
    scrapMonitorStarted = true

    folder.ChildAdded:Connect(function(child)
        if not ESPEnabled then return end
        task.wait(0.1)
        if child.Parent and (child:GetAttribute("Scrap") or child:IsA("Model") or child:IsA("Part")) then
            CreateESP(child, "Scrap")
        end
    end)
end

local function MonitorBearTraps()
    if trapMonitorStarted then return end
    local folder = GetBearTrapFolder()
    if not folder then
        task.delay(1, MonitorBearTraps)
        return
    end
    trapMonitorStarted = true

    folder.ChildAdded:Connect(function(child)
        if not BearTrapESPEnabled then return end
        task.wait(0.1)
        if child.Parent and child:IsA("Model") and child.Name == "BearTrap" then
            CreateESP(child, "BearTrap")
        end
    end)
end

local function MonitorLoot()
    if lootMonitorStarted then return end
    local folder = GetLootablesFolder()
    if not folder then
        task.delay(1, MonitorLoot)
        return
    end
    lootMonitorStarted = true

    -- Use DescendantAdded because items spawn deep inside container "Items" folders
    folder.DescendantAdded:Connect(function(descendant)
        if not LootESPEnabled then return end
        task.wait(0.1)
        if descendant.Parent and descendant.Parent.Name == "Items" then
            CreateESP(descendant, "Loot")
        end
    end)
end

